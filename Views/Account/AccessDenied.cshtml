@{
    ViewData["Title"] = "Acceso Denegado";
}

<div class="row justify-content-center align-items-center" style="min-height: 60vh;">
    <div class="col-md-6 text-center">
        <div class="p-5 rounded shadow-lg bg-white fade-in-up" style="border-radius: var(--radius-md); border-top: 5px solid #dc3545;">
            <div class="text-danger mb-4">
                <i class="bi bi-shield-slash" style="font-size: 5rem;"></i>
            </div>
            <h1 class="fw-bold mb-3">Acceso No Autorizado</h1>
            <p class="text-muted mb-4">Lo sentimos, no tienes los permisos o el rol necesario para acceder a este panel de administración.</p>
            <a href="/" class="btn btn-outline-secondary px-4 py-2" style="border-radius: var(--radius-sm);">
                <i class="bi bi-house"></i> Volver a la Tienda
            </a>
        </div>
    </div>
</div>
