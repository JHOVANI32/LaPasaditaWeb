@{
    ViewData["Title"] = "Mis Pedidos - La Pasadita";
}

<div class="container py-4 fade-in-up">
    <!-- Encabezado del Dashboard -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h1 class="fw-bold gradient-text m-0"><i class="bi bi-person-badge"></i> Panel de Miembro</h1>
            <p class="text-muted m-0">Bienvenido, <strong class="text-dark">@User.Identity?.Name</strong>. Rastrea tus pedidos y consulta tus compras en Axtla de Terrazas.</p>
        </div>
        <button class="btn btn-outline-success fw-bold" onclick="cargarPedidosCliente()" style="border-radius: var(--radius-sm);">
            <i class="bi bi-arrow-clockwise"></i> Actualizar Historial
        </button>
    </div>

    <!-- Navegación por Pestañas (Tabs) -->
    <ul class="nav nav-pills mb-4 border-bottom pb-2 gap-2" id="dashboardTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold text-success" id="pedidos-tab" data-bs-toggle="tab" data-bs-target="#pedidos-pane" type="button" role="tab" aria-controls="pedidos-pane" aria-selected="true" style="border-radius: var(--radius-sm);">
                <i class="bi bi-clock-history me-1"></i> Mis Pedidos
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold text-success" id="perfil-tab" data-bs-toggle="tab" data-bs-target="#perfil-pane" type="button" role="tab" aria-controls="perfil-pane" aria-selected="false" style="border-radius: var(--radius-sm);" onclick="cargarPerfilCliente()">
                <i class="bi bi-person-fill-gear me-1"></i> Mi Perfil
            </button>
        </li>
    </ul>

    <div class="tab-content" id="dashboardTabsContent">
        <!-- PESTAÑA DE PEDIDOS -->
        <div class="tab-pane fade show active" id="pedidos-pane" role="tabpanel" aria-labelledby="pedidos-tab">
            <div class="row g-4">
        <!-- Columna Izquierda: Historial de Compras -->
        <div class="col-md-5">
            <div class="card border-0 shadow-sm p-4 bg-white" style="border-radius: var(--radius-md); min-height: 400px;">
                <h4 class="fw-bold mb-3 text-dark"><i class="bi bi-clock-history"></i> Historial de Pedidos</h4>
                
                <div id="lista-pedidos-cliente" class="d-flex flex-column gap-3" style="max-height: 500px; overflow-y: auto;">
                    <!-- Cargado dinámicamente vía AJAX (Fetch) -->
                    <div class="text-center py-5 text-muted">
                        <div class="spinner-border text-success mb-3" role="status"></div>
                        <div>Cargando tus pedidos...</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Columna Derecha: Detalle de Pedido Seleccionado + Stepper de Seguimiento -->
        <div class="col-md-7">
            <div class="card border-0 shadow-sm p-4 bg-white" style="border-radius: var(--radius-md); min-height: 400px;" id="detalle-pedido-card">
                <div class="text-center py-5 text-muted" id="detalle-vacio-mensaje">
                    <i class="bi bi-receipt-cutoff display-1 text-muted opacity-50 mb-3"></i>
                    <h5>Selecciona un pedido para ver el detalle</h5>
                    <p class="small">Haz clic en cualquier pedido de la lista de la izquierda para ver su desglose de artículos y su estado de entrega en tiempo real.</p>
                </div>

                <!-- Contenedor del Detalle del Pedido (Oculto inicialmente) -->
                <div id="detalle-pedido-contenido" class="d-none">
                    <div class="d-flex justify-content-between align-items-start mb-4 border-bottom pb-3">
                        <div>
                            <h4 class="fw-bold m-0 text-success">Pedido <span id="det-pedido-id">#0</span></h4>
                            <span class="text-muted small" id="det-pedido-fecha">Cargando fecha...</span>
                        </div>
                        <span class="badge fs-6 px-3 py-2" id="det-pedido-estado">Pendiente</span>
                    </div>

                    <!-- Rastreador de Estado Visual (Stepper Premium) -->
                    <h5 class="fw-bold mb-3 text-dark"><i class="bi bi-geo-alt"></i> Estado del Envío</h5>
                    <div class="d-flex justify-content-between align-items-center mb-5 mt-4 stepper-wrapper px-3">
                        <div class="stepper-item" id="step-pendiente">
                            <div class="step-counter"><i class="bi bi-clock"></i></div>
                            <div class="step-name small mt-2 text-center">Pendiente</div>
                        </div>
                        <div class="stepper-item" id="step-preparando">
                            <div class="step-counter"><i class="bi bi-egg-fried"></i></div>
                            <div class="step-name small mt-2 text-center">Preparando</div>
                        </div>
                        <div class="stepper-item" id="step-en-camino">
                            <div class="step-counter"><i class="bi bi-bicycle"></i></div>
                            <div class="step-name small mt-2 text-center">En Camino</div>
                        </div>
                        <div class="stepper-item" id="step-entregado">
                            <div class="step-counter"><i class="bi bi-check-lg"></i></div>
                            <div class="step-name small mt-2 text-center">Entregado</div>
                        </div>
                    </div>

                    <!-- Resumen de Productos -->
                    <h5 class="fw-bold mb-3 text-dark"><i class="bi bi-basket3"></i> Artículos Comprados</h5>
                    <div class="table-responsive mb-4">
                        <table class="table table-sm align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Producto</th>
                                    <th class="text-center">Cant.</th>
                                    <th class="text-end">Precio</th>
                                    <th class="text-end">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody id="det-articulos-body">
                                <!-- Dinámico -->
                            </tbody>
                        </table>
                    </div>

                    <!-- Datos de Envío y Pago -->
                    <div class="row g-3 p-3 bg-light rounded mb-4">
                        <div class="col-md-6 border-end">
                            <div class="small fw-bold text-muted mb-1"><i class="bi bi-person-fill"></i> Cliente / Contacto:</div>
                            <div class="small mb-2" id="det-cliente-contacto">Cargando...</div>
                            <div class="small fw-bold text-muted mb-1"><i class="bi bi-geo-fill"></i> Dirección de Envío:</div>
                            <div class="small" id="det-direccion">Cargando dirección...</div>
                        </div>
                        <div class="col-md-6 ps-md-3">
                            <div class="small fw-bold text-muted mb-1"><i class="bi bi-wallet2"></i> Método de Pago:</div>
                            <div class="small mb-2" id="det-pago">Efectivo contra entrega</div>
                            <div class="small fw-bold text-success mt-2" style="font-size: 1.1rem;">Total Pagado: <span id="det-total">$0.00</span></div>
                        </div>
                    </div>

                    <!-- Acciones del Pedido (Solo si es Pendiente) -->
                    <div id="det-acciones-pendiente" class="d-none mb-4 p-3 border border-warning rounded-3 bg-warning bg-opacity-10" style="border-radius: var(--radius-sm);">
                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                            <div>
                                <strong class="text-dark small d-block"><i class="bi bi-info-circle-fill"></i> ¿Deseas modificar o cancelar?</strong>
                                <span class="text-muted" style="font-size: 0.75rem;">Mientras el pedido esté en estado "Pendiente", puedes modificar los datos o cancelarlo.</span>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-primary fw-bold" onclick="abrirModalEditarPedido()" style="border-radius: var(--radius-sm);">
                                    <i class="bi bi-pencil-square"></i> Modificar Pedido
                                </button>
                                <button class="btn btn-sm btn-danger fw-bold" onclick="confirmarCancelarPedido()" style="border-radius: var(--radius-sm);">
                                    <i class="bi bi-x-circle"></i> Cancelar Pedido
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Cupón Ganado (Se muestra solo si está Entregado) -->
                    <div id="det-cupon-ganado" class="d-none mb-4">
                        <div class="card border-0 text-white shadow-sm" style="background: linear-gradient(135deg, #f1c40f, #e67e22); border-radius: var(--radius-md);">
                            <div class="card-body text-center p-4">
                                <h4 class="fw-bold mb-2"><i class="bi bi-stars"></i> ¡Felicidades! Has ganado un cupón</h4>
                                <p class="mb-3">Por tu excelente compra, te regalamos este cupón para tu próximo pedido:</p>
                                <div class="bg-white text-dark py-2 px-4 d-inline-block fw-bold fs-4 mb-2" style="border-radius: var(--radius-sm); letter-spacing: 2px;" id="det-cupon-codigo">
                                    CÓDIGO
                                </div>
                                <div class="fw-bold fs-5 mb-1" id="det-cupon-valor">Valor del Cupón</div>
                                <div class="small text-white-50" id="det-cupon-expira">Válido hasta: ...</div>
                            </div>
                        </div>
                    </div>

                    <!-- Historial Logístico -->
                    <h5 class="fw-bold mb-3 text-dark"><i class="bi bi-journal-text"></i> Bitácora de Envío</h5>
                    <div class="list-group list-group-flush border rounded overflow-hidden" id="det-bitacora" style="max-height: 150px; overflow-y: auto;">
                        <!-- Dinámico -->
                    </div>
                </div>

            </div>
        </div>
    </div>
    </div>

    <!-- PESTAÑA DE MI PERFIL -->
    <div class="tab-pane fade" id="perfil-pane" role="tabpanel" aria-labelledby="perfil-tab">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card border-0 shadow-sm p-4 bg-white animate-fade-in" style="border-radius: var(--radius-md);">
                    <h4 class="fw-bold mb-3 text-dark border-bottom pb-2"><i class="bi bi-person-circle text-success"></i> Mi Perfil de Miembro</h4>
                    <p class="text-muted small mb-4">Mantén tus datos actualizados para facilitar tus envíos y entregas.</p>
                    
                    <form id="perfilClienteForm" onsubmit="guardarPerfilCliente(event)">
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label for="perfilNombre" class="form-label small fw-bold text-muted mb-1">Nombre Completo</label>
                                <input type="text" id="perfilNombre" class="form-control" required style="border-radius: var(--radius-sm);">
                            </div>
                            <div class="col-md-6">
                                <label for="perfilEmail" class="form-label small fw-bold text-muted mb-1">Correo Electrónico</label>
                                <input type="email" id="perfilEmail" class="form-control" required style="border-radius: var(--radius-sm);">
                            </div>
                            <div class="col-md-6">
                                <label for="perfilTelefono" class="form-label small fw-bold text-muted mb-1">Teléfono</label>
                                <input type="text" id="perfilTelefono" class="form-control" placeholder="ej. 4831234567" style="border-radius: var(--radius-sm);">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted mb-1">Rol de Usuario</label>
                                <input type="text" id="perfilRol" class="form-control bg-light" readonly style="border-radius: var(--radius-sm);">
                            </div>
                        </div>

                        <h5 class="fw-bold mb-3 border-top pt-3 text-dark"><i class="bi bi-shield-lock text-success"></i> Cambiar Contraseña</h5>
                        <p class="text-muted small mb-3">Si deseas cambiar tu contraseña, completa los campos de abajo. De lo contrario, déjalos en blanco.</p>

                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label for="perfilPasswordActual" class="form-label small fw-bold text-muted mb-1">Contraseña Actual</label>
                                <input type="password" id="perfilPasswordActual" class="form-control" placeholder="••••••••" style="border-radius: var(--radius-sm);">
                            </div>
                            <div class="col-md-4">
                                <label for="perfilPasswordNuevo" class="form-label small fw-bold text-muted mb-1">Nueva Contraseña</label>
                                <input type="password" id="perfilPasswordNuevo" class="form-control" placeholder="••••••••" style="border-radius: var(--radius-sm);">
                            </div>
                            <div class="col-md-4">
                                <label for="perfilPasswordConfirmar" class="form-label small fw-bold text-muted mb-1">Confirmar Nueva</label>
                                <input type="password" id="perfilPasswordConfirmar" class="form-control" placeholder="••••••••" style="border-radius: var(--radius-sm);">
                            </div>
                        </div>

                        <button type="submit" class="btn btn-success fw-bold px-4 py-2" style="border-radius: var(--radius-sm); background-color: var(--primary) !important; border: none;">
                            <i class="bi bi-save"></i> Guardar Cambios de Perfil
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- MODAL PARA EDITAR PEDIDO -->
<div class="modal fade" id="modalEditarPedido" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="modalEditarPedidoTitulo" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg" style="border-radius: var(--radius-md);">
            <div class="modal-header bg-success text-white py-3" style="background-color: var(--primary) !important; border-top-left-radius: var(--radius-md); border-top-right-radius: var(--radius-md);">
                <h5 class="modal-title fw-bold" id="modalEditarPedidoTitulo"><i class="bi bi-pencil-square"></i> Modificar Pedido <span id="modal-edit-pedido-id">#0</span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form id="editarPedidoForm">
                    <input type="hidden" id="editPedidoId">
                    <h6 class="fw-bold mb-3 border-bottom pb-2 text-success"><i class="bi bi-person-lines-fill"></i> Datos de Contacto y Envío</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label for="editNombre" class="form-label small fw-bold text-muted">Nombre del Destinatario</label>
                            <input type="text" id="editNombre" class="form-control" required style="border-radius: var(--radius-sm);">
                        </div>
                        <div class="col-md-6">
                            <label for="editTelefono" class="form-label small fw-bold text-muted">Teléfono de Contacto</label>
                            <input type="text" id="editTelefono" class="form-control" required style="border-radius: var(--radius-sm);">
                        </div>
                        <div class="col-12">
                            <label for="editDireccion" class="form-label small fw-bold text-muted">Dirección Completa de Envío</label>
                            <textarea id="editDireccion" class="form-control" rows="2" required style="border-radius: var(--radius-sm);"></textarea>
                        </div>
                    </div>

                    <!-- Añadir Nuevo Producto a la Edición -->
                    <h6 class="fw-bold mb-3 border-bottom pb-2 text-success"><i class="bi bi-plus-circle-fill"></i> Añadir Producto al Pedido</h6>
                    <div class="row g-2 mb-4 align-items-end">
                        <div class="col-md-8">
                            <label for="selectNuevoProducto" class="form-label small fw-bold text-muted mb-1">Selecciona un producto para añadir</label>
                            <select id="selectNuevoProducto" class="form-select" style="border-radius: var(--radius-sm);">
                                <option value="">Cargando catálogo de productos...</option>
                            </select>
                        </div>
                        <div class="col-md-4 d-grid">
                            <button type="button" class="btn btn-outline-success fw-bold" onclick="agregarNuevoProductoAEdicion()" style="border-radius: var(--radius-sm); min-height: 38px;">
                                <i class="bi bi-cart-plus-fill"></i> Agregar Producto
                            </button>
                        </div>
                    </div>

                    <h6 class="fw-bold mb-3 border-bottom pb-2 text-success"><i class="bi bi-basket-fill"></i> Artículos del Pedido</h6>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Producto</th>
                                    <th class="text-center" style="width: 130px;">Cantidad</th>
                                    <th class="text-end">Precio Unitario</th>
                                    <th class="text-end">Subtotal</th>
                                    <th class="text-center" style="width: 50px;"></th>
                                </tr>
                            </thead>
                            <tbody id="edit-articulos-body">
                                <!-- Dinámico -->
                            </tbody>
                        </table>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-outline-secondary fw-bold px-4" data-bs-dismiss="modal" style="border-radius: var(--radius-sm);">Cerrar</button>
                <button type="button" class="btn btn-success fw-bold px-4" onclick="guardarCambiosPedido()" style="border-radius: var(--radius-sm); background-color: var(--primary) !important; border: none;">Guardar Cambios</button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Estilos del Stepper de Estado */
    .stepper-wrapper {
        position: relative;
    }
    .stepper-wrapper::after {
        content: '';
        position: absolute;
        top: 20px;
        left: 40px;
        right: 40px;
        height: 4px;
        background-color: #e9ecef;
        z-index: 1;
    }
    .stepper-item {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
    }
    .step-counter {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background-color: #e9ecef;
        color: #6c757d;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 1.2rem;
        transition: all 0.3s ease;
        border: 3px solid #fff;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }
    
    /* Estados activos y completados */
    .stepper-item.completed .step-counter {
        background-color: #2e7d32;
        color: white;
    }
    .stepper-item.active .step-counter {
        background-color: #d84315;
        color: white;
        transform: scale(1.15);
        box-shadow: 0 0 0 4px rgba(216, 67, 21, 0.2);
    }
    .stepper-item.completed .step-name {
        color: #2e7d32;
        font-weight: 600;
    }
    .stepper-item.active .step-name {
        color: #d84315;
        font-weight: 700;
    }
    .stepper-item.cancelled .step-counter {
        background-color: #c62828;
        color: white;
    }
    .stepper-item.cancelled .step-name {
        color: #c62828;
        font-weight: 700;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        let pedidosLocales = [];

        document.addEventListener("DOMContentLoaded", () => {
            cargarPedidosCliente();
        });

        // Obtener historial de pedidos mediante AJAX (Fetch)
        function cargarPedidosCliente() {
            const usuarioId = window.UsuarioId;
            const lista = document.getElementById("lista-pedidos-cliente");

            if (!usuarioId) {
                lista.innerHTML = `
                    <div class="alert alert-danger border-0 text-center">
                        <i class="bi bi-shield-exclamation fs-3"></i>
                        <p class="mt-2 small">Debes estar registrado para consultar el panel.</p>
                    </div>`;
                return;
            }

            fetch(`/api/ClientePedidosApi?usuarioId=${usuarioId}`)
                .then(res => {
                    if (!res.ok) throw new Error("No autorizado");
                    return res.json();
                })
                .then(data => {
                    pedidosLocales = data;
                    renderizarListaPedidos(data);
                })
                .catch(err => {
                    console.error("Error al cargar pedidos:", err);
                    lista.innerHTML = `
                        <div class="text-center py-4 text-danger small">
                            <i class="bi bi-exclamation-triangle fs-3"></i>
                            <p class="mt-1">Error al conectar con la base de datos.</p>
                        </div>`;
                });
        }

        // Renderizar la lista lateral de pedidos
        function renderizarListaPedidos(pedidos) {
            const lista = document.getElementById("lista-pedidos-cliente");
            if (pedidos.length === 0) {
                lista.innerHTML = `
                    <div class="text-center py-5 text-muted small">
                        <i class="bi bi-bag-x fs-1 opacity-50"></i>
                        <p class="mt-2">Aún no has realizado ninguna compra con esta cuenta.</p>
                        <a href="/" class="btn btn-sm btn-outline-success mt-2">Explorar Catálogo</a>
                    </div>`;
                return;
            }

            let html = "";
            pedidos.forEach(p => {
                let badgeColor = "bg-warning text-dark";
                if (p.estado === "Preparando") badgeColor = "bg-info text-white";
                else if (p.estado === "En Camino" || p.estado === "Enviado") badgeColor = "bg-primary text-white";
                else if (p.estado === "Entregado") badgeColor = "bg-success text-white";
                else if (p.estado === "Cancelado") badgeColor = "bg-danger text-white";

                const fecha = new Date(p.fechaPedido).toLocaleDateString('es-MX', {
                    day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit'
                });

                html += `
                    <div class="card p-3 border shadow-sm item-pedido-click" onclick="seleccionarPedido(${p.id})" style="border-radius: var(--radius-sm); cursor: pointer; transition: all 0.2s ease;">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="fw-extrabold text-success">Pedido #${p.id}</span>
                            <span class="badge ${badgeColor}">${p.estado}</span>
                        </div>
                        <div class="text-muted small mb-1"><i class="bi bi-calendar3"></i> ${fecha}</div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">${p.detalles.length} productos</span>
                            <span class="fw-bold text-dark fs-5">$${p.total.toFixed(2)}</span>
                        </div>
                    </div>
                `;
            });

            lista.innerHTML = html;
        }

        // Mostrar detalle de pedido específico
        window.seleccionarPedido = function(id) {
            const pedido = pedidosLocales.find(p => p.id === id);
            if (!pedido) return;

            // Iluminar la tarjeta lateral seleccionada (opcional estética)
            document.querySelectorAll(".item-pedido-click").forEach(el => {
                el.classList.remove("border-success", "bg-success", "bg-opacity-10");
            });
            event.currentTarget.classList.add("border-success", "bg-success", "bg-opacity-10");

            // Ocultar mensaje vacío y mostrar contenido
            document.getElementById("detalle-vacio-mensaje").classList.add("d-none");
            document.getElementById("detalle-pedido-contenido").classList.remove("d-none");

            // Cargar datos estáticos del pedido
            document.getElementById("det-pedido-id").textContent = `#${pedido.id}`;
            document.getElementById("det-pedido-fecha").textContent = new Date(pedido.fechaPedido).toLocaleString('es-MX');
            document.getElementById("det-direccion").textContent = pedido.direccionEnvio;
            document.getElementById("det-cliente-contacto").textContent = `${pedido.nombreCliente} ${pedido.telefonoCliente ? '(Tel: ' + pedido.telefonoCliente + ')' : ''}`;
            document.getElementById("det-pago").textContent = `Pago en ${pedido.metodoPago} contra entrega`;
            document.getElementById("det-total").textContent = `$${pedido.total.toFixed(2)}`;

            // Mostrar/ocultar panel de acciones de edición/cancelación
            const accionesDiv = document.getElementById("det-acciones-pendiente");
            if (pedido.estado === "Pendiente") {
                accionesDiv.classList.remove("d-none");
            } else {
                accionesDiv.classList.add("d-none");
            }

            const estBadge = document.getElementById("det-pedido-estado");
            estBadge.textContent = pedido.estado;
            estBadge.className = "badge fs-6 px-3 py-2 ";
            if (pedido.estado === "Pendiente") estBadge.classList.add("bg-warning", "text-dark");
            else if (pedido.estado === "Preparando") estBadge.classList.add("bg-info", "text-white");
            else if (pedido.estado === "En Camino" || pedido.estado === "Enviado") estBadge.classList.add("bg-primary", "text-white");
            else if (pedido.estado === "Entregado") estBadge.classList.add("bg-success", "text-white");
            else estBadge.classList.add("bg-danger", "text-white");

            // Cargar Artículos en la tabla
            const tbody = document.getElementById("det-articulos-body");
            let artHtml = "";
            pedido.detalles.forEach(art => {
                artHtml += `
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="${art.imagenUrl || 'https://images.unsplash.com/photo-1542838132-92c53300491e?w=50&q=80'}" alt="${art.nombreProducto}" style="width: 30px; height: 30px; object-fit: cover; border-radius: 4px;">
                                <span class="fw-semibold text-dark">${art.nombreProducto}</span>
                            </div>
                        </td>
                        <td class="text-center">${art.cantidad}</td>
                        <td class="text-end">$${art.precioUnitario.toFixed(2)}</td>
                        <td class="text-end fw-bold text-muted">$${art.subtotal.toFixed(2)}</td>
                    </tr>
                `;
            });
            tbody.innerHTML = artHtml;

            // Mostrar cupón si el estado es Entregado y hay cupón ganado
            const divCupon = document.getElementById("det-cupon-ganado");
            if (pedido.estado === "Entregado" && pedido.cuponGenerado) {
                document.getElementById("det-cupon-codigo").textContent = pedido.cuponGenerado.codigo;
                let valor = pedido.cuponGenerado.tipoDescuento === "Fijo" 
                    ? `$${pedido.cuponGenerado.valor.toFixed(2)} MXN` 
                    : `${pedido.cuponGenerado.valor}% de Descuento`;
                document.getElementById("det-cupon-valor").textContent = valor;
                
                const expira = new Date(pedido.cuponGenerado.fechaExpiracion).toLocaleDateString('es-MX');
                document.getElementById("det-cupon-expira").textContent = `Válido hasta: ${expira}`;
                
                divCupon.classList.remove("d-none");
            } else {
                divCupon.classList.add("d-none");
            }

            // Configurar el Stepper de Estados
            configurarStepper(pedido.estado);

            // Cargar Bitácora de envío
            const bitacora = document.getElementById("det-bitacora");
            let bitHtml = "";
            if (pedido.historialEstados.length === 0) {
                bitHtml = `<div class="list-group-item text-center text-muted small py-3">No hay historial registrado.</div>`;
            } else {
                pedido.historialEstados.forEach(h => {
                    const hFecha = new Date(h.fechaCambio).toLocaleTimeString('es-MX', {
                        hour: '2-digit', minute: '2-digit'
                    });
                    bitHtml += `
                        <div class="list-group-item bg-transparent py-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <strong class="small text-dark">${h.estadoNuevo}</strong>
                                <span class="text-muted" style="font-size: 0.75rem;">${hFecha}</span>
                            </div>
                            <p class="m-0 text-muted" style="font-size: 0.75rem;">${h.notas || 'Sin notas.'}</p>
                        </div>
                    `;
                });
            }
            bitacora.innerHTML = bitHtml;
        };

        // Función para colorear el Stepper
        function configurarStepper(estadoActual) {
            const steps = ["Pendiente", "Preparando", "En Camino", "Entregado"];
            
            // Limpiar clases
            document.querySelectorAll(".stepper-item").forEach(el => {
                el.className = "stepper-item";
            });

            if (estadoActual === "Cancelado") {
                const stepPendiente = document.getElementById("step-pendiente");
                stepPendiente.classList.add("cancelled");
                stepPendiente.querySelector(".step-name").textContent = "Cancelado";
                return;
            }

            // Restaurar texto de pendiente por si fue cancelado antes
            document.getElementById("step-pendiente").querySelector(".step-name").textContent = "Pendiente";

            const idxActual = steps.indexOf(estadoActual);
            
            steps.forEach((step, idx) => {
                const el = document.getElementById(`step-${step.toLowerCase().replace(" ", "-")}`);
                if (!el) return;

                if (idx < idxActual) {
                    el.classList.add("completed");
                } else if (idx === idxActual) {
                    el.classList.add("active");
                }
            });
        }

        window.confirmarCancelarPedido = function() {
            const pedidoId = document.getElementById("det-pedido-id").textContent.replace("#", "");
            
            Swal.fire({
                title: '¿Estás seguro?',
                text: `¿Deseas cancelar el pedido #${pedidoId}? Esta acción devolverá los productos al stock y no se puede deshacer.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Sí, cancelar pedido',
                cancelButtonText: 'No, mantener pedido',
                background: '#ffffff',
                customClass: {
                    popup: 'swal2-border-radius'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Cancelando pedido...',
                        allowOutsideClick: false,
                        didOpen: () => {
                            Swal.showLoading();
                        }
                    });

                    fetch(`/api/ClientePedidosApi/${pedidoId}/cancelar`, {
                        method: "POST"
                    })
                    .then(async res => {
                        const data = await res.json();
                        if (!res.ok) throw new Error(data.mensaje || "Error al cancelar el pedido.");
                        return data;
                    })
                    .then(data => {
                        Swal.fire({
                            title: '¡Cancelado!',
                            text: data.mensaje,
                            icon: 'success',
                            confirmButtonColor: '#2e7d32'
                        });
                        cargarPedidosCliente(); // Recargar la lista
                        setTimeout(() => {
                            seleccionarPedido(parseInt(pedidoId));
                        }, 500);
                    })
                    .catch(err => {
                        let msg = err.message;
                        if (msg === "Failed to fetch") {
                            msg = "No se pudo conectar con el servidor. Es muy probable que Railway esté reiniciando el servidor para aplicar la última actualización. Por favor, espera 1 minuto y vuelve a intentar.";
                        }
                        Swal.fire({
                            title: 'Error',
                            text: msg,
                            icon: 'error',
                            confirmButtonColor: '#d33'
                        });
                    });
                }
            });
        };

        let articulosEditar = []; // Guardará temporalmente los productos a editar
        let catalogoProductos = []; // Guardará los productos activos de la tienda

        window.abrirModalEditarPedido = function() {
            const pedidoId = document.getElementById("det-pedido-id").textContent.replace("#", "");
            const pedido = pedidosLocales.find(p => p.id === parseInt(pedidoId));
            if (!pedido) return;

            document.getElementById("modal-edit-pedido-id").textContent = `#${pedido.id}`;
            document.getElementById("editPedidoId").value = pedido.id;
            document.getElementById("editNombre").value = pedido.nombreCliente || "";
            document.getElementById("editTelefono").value = pedido.telefonoCliente || "";
            document.getElementById("editDireccion").value = pedido.direccionEnvio || "";

            // Clonar artículos del pedido para editar de forma segura
            articulosEditar = pedido.detalles.map(d => ({
                id: d.id,
                productoId: d.productoId,
                nombreProducto: d.nombreProducto,
                imagenUrl: d.imagenUrl,
                cantidad: d.cantidad,
                precioUnitario: d.precioUnitario,
                subtotal: d.subtotal
            }));

            // Cargar catálogo de productos activos para poder añadir nuevos productos
            const select = document.getElementById("selectNuevoProducto");
            select.innerHTML = '<option value="">Cargando catálogo...</option>';

            fetch("/api/CatalogoApi")
                .then(res => {
                    if (!res.ok) throw new Error("No se pudo cargar el catálogo.");
                    return res.json();
                })
                .then(data => {
                    catalogoProductos = data.productos || [];
                    let optionsHtml = '<option value="">-- Selecciona un producto para agregar --</option>';
                    catalogoProductos.forEach(p => {
                        optionsHtml += `<option value="${p.id}">${p.nombre} - $${p.precio.toFixed(2)} (Stock: ${p.stock})</option>`;
                    });
                    select.innerHTML = optionsHtml;
                })
                .catch(err => {
                    console.error("Error al obtener catálogo:", err);
                    select.innerHTML = '<option value="">Error al cargar catálogo de productos</option>';
                });

            renderizarArticulosEdicion();

            // Abrir modal de Bootstrap
            const modalEl = document.getElementById("modalEditarPedido");
            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
            modal.show();
        };

        window.agregarNuevoProductoAEdicion = function() {
            const select = document.getElementById("selectNuevoProducto");
            const prodId = parseInt(select.value);
            if (!prodId) {
                alert("Por favor selecciona un producto válido.");
                return;
            }

            const existe = articulosEditar.some(a => a.productoId === prodId);
            if (existe) {
                alert("Este producto ya está en tu pedido. Puedes modificar su cantidad en la tabla de abajo.");
                return;
            }

            const prod = catalogoProductos.find(p => p.id === prodId);
            if (!prod) return;

            articulosEditar.push({
                id: 0,
                productoId: prod.id,
                nombreProducto: prod.nombre,
                imagenUrl: prod.imagenUrl,
                cantidad: 1,
                precioUnitario: prod.precio,
                subtotal: prod.precio
            });

            select.value = "";
            renderizarArticulosEdicion();
        };

        function renderizarArticulosEdicion() {
            const tbody = document.getElementById("edit-articulos-body");
            let html = "";

            if (articulosEditar.length === 0) {
                html = `<tr><td colspan="5" class="text-center py-4 text-muted">No hay artículos en este pedido. Agrégalos o cancela el pedido.</td></tr>`;
            } else {
                articulosEditar.forEach((art, idx) => {
                    html += `
                        <tr id="edit-row-${art.productoId}">
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="${art.imagenUrl || 'https://images.unsplash.com/photo-1542838132-92c53300491e?w=50&q=80'}" alt="${art.nombreProducto}" style="width: 30px; height: 30px; object-fit: cover; border-radius: 4px;">
                                    <span class="fw-semibold text-dark small">${art.nombreProducto}</span>
                                </div>
                            </td>
                            <td class="text-center">
                                <div class="input-group input-group-sm justify-content-center">
                                    <button class="btn btn-outline-secondary px-2" type="button" onclick="cambiarCantEdicion(${art.productoId}, -1)">-</button>
                                    <input type="text" class="form-control text-center bg-white" value="${art.cantidad}" readonly style="max-width: 45px;">
                                    <button class="btn btn-outline-secondary px-2" type="button" onclick="cambiarCantEdicion(${art.productoId}, 1)">+</button>
                                </div>
                            </td>
                            <td class="text-end small">$${art.precioUnitario.toFixed(2)}</td>
                            <td class="text-end fw-bold text-muted small">$${(art.cantidad * art.precioUnitario).toFixed(2)}</td>
                            <td class="text-center">
                                <button type="button" class="btn btn-sm btn-link text-danger p-0" onclick="eliminarArtEdicion(${art.productoId})">
                                    <i class="bi bi-trash fs-5"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                });
            }
            tbody.innerHTML = html;
        }

        window.cambiarCantEdicion = function(prodId, delta) {
            const art = articulosEditar.find(a => a.productoId === prodId);
            if (!art) return;

            const nuevaCant = art.cantidad + delta;
            if (nuevaCant < 1) return;

            art.cantidad = nuevaCant;
            renderizarArticulosEdicion();
        };

        window.eliminarArtEdicion = function(prodId) {
            Swal.fire({
                title: '¿Remover artículo?',
                text: '¿Deseas quitar este producto de tu pedido?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Sí, remover',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    articulosEditar = articulosEditar.filter(a => a.productoId !== prodId);
                    renderizarArticulosEdicion();
                }
            });
        };

        window.guardarCambiosPedido = function() {
            const pedidoId = document.getElementById("editPedidoId").value;
            const nombre = document.getElementById("editNombre").value.trim();
            const telefono = document.getElementById("editTelefono").value.trim();
            const direccion = document.getElementById("editDireccion").value.trim();

            if (!nombre || !telefono || !direccion) {
                Swal.fire({
                    title: 'Datos Incompletos',
                    text: 'Por favor completa los datos de destinatario, teléfono y dirección.',
                    icon: 'warning',
                    confirmButtonColor: '#3085d6'
                });
                return;
            }

            if (articulosEditar.length === 0) {
                Swal.fire({
                    title: 'Pedido Vacío',
                    text: 'Debes tener al menos un artículo en tu pedido. Si no deseas comprar nada, puedes cancelar el pedido.',
                    icon: 'warning',
                    confirmButtonColor: '#3085d6'
                });
                return;
            }

            const payload = {
                nombreCliente: nombre,
                telefonoCliente: telefono,
                direccionEnvio: direccion,
                detalles: articulosEditar.map(a => ({
                    productoId: a.productoId,
                    cantidad: a.cantidad
                }))
            };

            Swal.fire({
                title: 'Guardando cambios...',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            fetch(`/api/ClientePedidosApi/${pedidoId}/editar`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
            })
            .then(async res => {
                const data = await res.json();
                if (!res.ok) throw new Error(data.mensaje || "Error al modificar el pedido.");
                return data;
            })
            .then(data => {
                Swal.fire({
                    title: '¡Modificado!',
                    text: data.mensaje,
                    icon: 'success',
                    confirmButtonColor: '#2e7d32'
                });
                
                // Cerrar modal
                const modalEl = document.getElementById("modalEditarPedido");
                const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                modal.hide();

                cargarPedidosCliente(); // Recargar la lista
                setTimeout(() => {
                    seleccionarPedido(parseInt(pedidoId));
                }, 500);
            })
            .catch(err => {
                let msg = err.message;
                if (msg === "Failed to fetch") {
                    msg = "No se pudo conectar con el servidor. Es muy probable que Railway esté reiniciando el servidor para aplicar la última actualización. Por favor, espera 1 minuto y vuelve a intentar.";
                }
                Swal.fire({
                    title: 'Error',
                    text: msg,
                    icon: 'error',
                    confirmButtonColor: '#d33'
                });
            });
        };

        window.cargarPerfilCliente = function() {
            fetch("/api/Perfil")
                .then(res => {
                    if (!res.ok) throw new Error("No autorizado");
                    return res.json();
                })
                .then(data => {
                    document.getElementById("perfilNombre").value = data.nombre || "";
                    document.getElementById("perfilEmail").value = data.email || "";
                    document.getElementById("perfilTelefono").value = data.telefono || "";
                    document.getElementById("perfilRol").value = data.rol || "";
                    
                    document.getElementById("perfilPasswordActual").value = "";
                    document.getElementById("perfilPasswordNuevo").value = "";
                    document.getElementById("perfilPasswordConfirmar").value = "";
                })
                .catch(err => {
                    console.error("Error al cargar perfil:", err);
                    Swal.fire({
                        title: 'Error',
                        text: 'No se pudo cargar el perfil del usuario.',
                        icon: 'error',
                        confirmButtonColor: '#d33'
                    });
                });
        };

        window.guardarPerfilCliente = function(e) {
            e.preventDefault();

            const nombre = document.getElementById("perfilNombre").value.trim();
            const email = document.getElementById("perfilEmail").value.trim();
            const telefono = document.getElementById("perfilTelefono").value.trim();
            const passActual = document.getElementById("perfilPasswordActual").value;
            const passNuevo = document.getElementById("perfilPasswordNuevo").value;
            const passConfirm = document.getElementById("perfilPasswordConfirmar").value;

            if (!nombre || !email) {
                Swal.fire({
                    title: 'Campos requeridos',
                    text: 'Nombre y Correo electrónico son obligatorios.',
                    icon: 'warning',
                    confirmButtonColor: '#3085d6'
                });
                return;
            }

            if (passNuevo || passConfirm || passActual) {
                if (!passActual) {
                    Swal.fire({
                        title: 'Contraseña Requerida',
                        text: 'Debes ingresar tu contraseña actual para establecer una nueva.',
                        icon: 'warning',
                        confirmButtonColor: '#3085d6'
                    });
                    return;
                }
                if (passNuevo !== passConfirm) {
                    Swal.fire({
                        title: 'Error de Confirmación',
                        text: 'La nueva contraseña y su confirmación no coinciden.',
                        icon: 'warning',
                        confirmButtonColor: '#3085d6'
                    });
                    return;
                }
                if (passNuevo.length < 4) {
                    Swal.fire({
                        title: 'Contraseña muy corta',
                        text: 'La nueva contraseña debe tener al menos 4 caracteres.',
                        icon: 'warning',
                        confirmButtonColor: '#3085d6'
                    });
                    return;
                }
            }

            const payload = {
                nombre: nombre,
                email: email,
                telefono: telefono,
                passwordActual: passActual || null,
                passwordNuevo: passNuevo || null
            };

            Swal.fire({
                title: 'Actualizando perfil...',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            fetch("/api/Perfil", {
                method: "PUT",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
            })
            .then(async res => {
                const data = await res.json();
                if (!res.ok) throw new Error(data.mensaje || "Error al actualizar el perfil.");
                return data;
            })
            .then(data => {
                Swal.fire({
                    title: '¡Perfil Actualizado!',
                    text: data.mensaje,
                    icon: 'success',
                    confirmButtonColor: '#2e7d32'
                });
                
                const welcomeName = document.querySelector(".gradient-text + p strong");
                if (welcomeName) {
                    welcomeName.textContent = nombre;
                }

                cargarPerfilCliente();
            })
            .catch(err => {
                let msg = err.message;
                if (msg === "Failed to fetch") {
                    msg = "No se pudo conectar con el servidor. Es muy probable que Railway esté reiniciando el servidor. Por favor, espera 1 minuto y vuelve a intentar.";
                }
                Swal.fire({
                    title: 'Error',
                    text: msg,
                    icon: 'error',
                    confirmButtonColor: '#d33'
                });
            });
        };
    </script>
}
