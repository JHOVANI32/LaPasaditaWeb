<!-- MODAL BOOTSTRAP PARA CARGA MASIVA DE EXCEL -->
<div class="modal fade" id="modalCargaMasiva" tabindex="-1" aria-labelledby="modalCargaMasivaTitulo" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: var(--radius-md);">
            <div class="modal-header bg-success text-white py-3" style="background-color: var(--primary) !important; border-top-left-radius: var(--radius-md); border-top-right-radius: var(--radius-md);">
                <h5 class="modal-title fw-bold" id="modalCargaMasivaTitulo">Carga Masiva de Productos (Excel)</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <p class="text-muted small">Agrega o actualiza múltiples productos a la vez subiendo un archivo Excel <code>.xlsx</code>. El sistema identificará los productos por su nombre y creará las categorías automáticamente si no existen.</p>
                
                <div class="d-grid mb-4">
                    <button class="btn btn-outline-secondary fw-bold" onclick="window.location.href='/api/AdminProductosApi/plantilla-excel'">
                        <i class="bi bi-cloud-download"></i> Descargar Inventario Actual
                    </button>
                </div>

                <form id="formCargaMasiva" onsubmit="event.preventDefault(); subirArchivoExcel();">
                    <div class="mb-3">
                        <label for="archivoExcel" class="form-label small fw-bold text-muted">Seleccionar Archivo .xlsx *</label>
                        <input class="form-control" type="file" id="archivoExcel" accept=".xlsx" required style="border-radius: var(--radius-sm);">
                    </div>
                    
                    <div id="progresoCargaMasiva" class="d-none text-center py-2">
                        <div class="spinner-border text-success spinner-border-sm" role="status">
                            <span class="visually-hidden">Procesando...</span>
                        </div>
                        <span class="ms-2 text-success fw-bold small" id="mensajeCargaMasiva">Procesando archivo...</span>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-success fw-bold py-2" id="btnSubirExcel" style="border-radius: var(--radius-sm); background-color: var(--primary); border: none;">
                            <i class="bi bi-upload"></i> Subir y Procesar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/admin.js" asp-append-version="true"></script>
    <!-- Chart.js para las gráficas -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var ctx = document.getElementById('ventasChart');
            if (ctx) {
                var labels = @Html.Raw(ViewBag.ChartLabels);
                var data = @Html.Raw(ViewBag.ChartData);
                
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Ventas Diarias ($)',
                            data: data,
                            borderColor: '#27ae60',
                            backgroundColor: 'rgba(39, 174, 96, 0.1)',
                            borderWidth: 3,
                            pointBackgroundColor: '#27ae60',
                            pointBorderColor: '#fff',
                            pointHoverBackgroundColor: '#fff',
                            pointHoverBorderColor: '#27ae60',
                            fill: true,
                            tension: 0.4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        let label = context.dataset.label || '';
                                        if (label) {
                                            label += ': ';
                                        }
                                        if (context.parsed.y !== null) {
                                            label += new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN' }).format(context.parsed.y);
                                        }
                                        return label;
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    callback: function(value, index, values) {
                                        return '$' + value;
                                    }
                                }
                            }
                        }
                    }
                });
            }
        });
    </script>
}
