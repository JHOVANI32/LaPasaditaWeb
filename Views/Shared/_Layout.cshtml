<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - La Pasadita</title>
    
    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <!-- Bootstrap Icons CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <!-- CSS Personalizado Premium -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LaPasaditaWeb.styles.css" asp-append-version="true" />
    
    <!-- CSS Chatbot -->
    <style>
        .chatbot-btn {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background-color: var(--primary);
            color: white;
            border-radius: 50%;
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            z-index: 1000;
            transition: transform 0.2s;
        }
        .chatbot-btn:hover { transform: scale(1.1); }
        .chat-window {
            position: fixed;
            bottom: 90px;
            right: 20px;
            width: 350px;
            background-color: white;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            display: none;
            flex-direction: column;
            overflow: hidden;
            z-index: 1000;
            border: 1px solid #ddd;
        }
        .chat-header { background-color: var(--primary); color: white; padding: 15px; font-weight: bold; display: flex; justify-content: space-between; align-items: center; }
        .chat-messages { height: 300px; overflow-y: auto; padding: 15px; display: flex; flex-direction: column; gap: 10px; background-color: #f8f9fa; }
        .msg { max-width: 80%; padding: 10px; border-radius: 10px; font-size: 14px; line-height: 1.4; }
        .msg-user { background-color: var(--primary); color: white; align-self: flex-end; border-bottom-right-radius: 2px; }
        .msg-ai { background-color: #e9ecef; color: #333; align-self: flex-start; border-bottom-left-radius: 2px; }
        .chat-input { display: flex; padding: 10px; border-top: 1px solid #ddd; }
        .chat-input input { flex: 1; padding: 8px; border: 1px solid #ccc; border-radius: 20px; outline: none; }
        .chat-input button { background-color: var(--primary); color: white; border: none; border-radius: 50%; width: 36px; height: 36px; margin-left: 10px; cursor: pointer; display: flex; align-items: center; justify-content: center; }
        
        /* Responsive para Móviles */
        @@media (max-width: 576px) {
            .chat-window {
                width: 100vw;
                height: 100vh;
                bottom: 0;
                right: 0;
                border-radius: 0;
                display: none; /* Se mantiene oculto por defecto */
            }
            .chat-messages {
                flex-grow: 1;
                height: auto;
            }
            .chat-header {
                border-radius: 0;
            }
            .chatbot-btn {
                bottom: 15px;
                right: 15px;
            }
        }
    </style>
</head>
<body>
    <!-- Navbar Premium Glassmorphism -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-custom navbar-light py-3">
            <div class="container">
                <a class="navbar-brand navbar-brand-custom" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-basket3 text-success"></i> La Pasadita <span class="dot"></span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent"
                        aria-expanded="false" aria-label="Toggle navigation" style="box-shadow: none;">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link nav-link-custom active" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door"></i> Inicio
                            </a>
                        </li>
                        <li class="nav-item">
                            @if (User.IsInRole("Admin"))
                            {
                                <a class="nav-link nav-link-custom" href="/Admin/Dashboard#promociones-pane">
                                    <i class="bi bi-tags"></i> Ofertas
                                </a>
                            }
                            else
                            {
                                <a class="nav-link nav-link-custom" href="/#ofertas">
                                    <i class="bi bi-tags"></i> Ofertas
                                </a>
                            }
                        </li>
                    </ul>
                    
                    <div class="d-flex align-items-center gap-3">
                        <!-- Widget Clima -->
                        <div id="weather-widget" class="d-none d-lg-flex align-items-center bg-light text-dark px-3 py-1 rounded-pill shadow-sm border" style="font-size: 0.9rem; cursor: help;" title="Clima Local">
                            <div class="spinner-border spinner-border-sm text-primary me-2" role="status" id="weather-spinner">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                            <i id="weather-icon" class="bi d-none me-2 fs-5 text-primary"></i>
                            <span id="weather-temp" class="fw-bold text-muted">Clima...</span>
                        </div>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <div class="dropdown">
                                <button class="btn btn-outline-success border-2 fw-bold dropdown-toggle" type="button" id="dropdownUserMenu" data-bs-toggle="dropdown" aria-expanded="false" style="border-radius: var(--radius-sm);">
                                    <i class="bi bi-person-circle"></i> @User.Identity.Name
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="dropdownUserMenu" style="border-radius: var(--radius-md);">
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><a class="dropdown-item fw-semibold" asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-speedometer2"></i> Panel Admin</a></li>
                                    }
                                    else
                                    {
                                        <li><a class="dropdown-item fw-semibold" asp-controller="Cliente" asp-action="Dashboard"><i class="bi bi-card-list"></i> Mis Pedidos</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="dropdown-item text-danger fw-semibold"><i class="bi bi-box-arrow-right"></i> Cerrar Sesión</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn btn-outline-success border-2 fw-bold text-success" asp-controller="Account" asp-action="Login" style="border-radius: var(--radius-sm);">
                                <i class="bi bi-shield-lock"></i> Iniciar Sesión
                            </a>
                        }

                        <!-- Disparador del Carrito Flotante -->
                        <button class="cart-trigger" id="btn-abrir-carrito">
                            <i class="bi bi-cart3"></i>
                            <span>Mi Carrito</span>
                            <span class="cart-badge" id="count-carrito">0</span>
                        </button>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- Contenido Principal -->
    <div class="container">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <!-- Carrito Deslizante (Drawer / Silent Cart) -->
    <div class="cart-overlay" id="cart-overlay"></div>
    <div class="cart-sidebar" id="cart-sidebar">
        <div class="cart-header">
            <h5><i class="bi bi-cart3"></i> Carrito Silencioso</h5>
            <button class="btn-close-cart" id="btn-cerrar-carrito">&times;</button>
        </div>
        <div class="cart-body" id="lista-carrito">
            <!-- Se carga dinámicamente vía AJAX -->
        </div>
        <div class="cart-footer">
            <div class="cart-total-row">
                <span>Total Estimado:</span>
                <span class="cart-total-price" id="total-carrito">$0.00</span>
            </div>
            <button class="btn-checkout" onclick="window.location.href='/Home/Checkout'">
                <i class="bi bi-credit-card"></i> Proceder a Pagar
            </button>
        </div>
    </div>

    <!-- Chatbot Widget -->
    <div class="chatbot-btn" id="chatbotBtn" onclick="toggleChat()">
        <i class="bi bi-chat-dots-fill"></i>
    </div>

    <div class="chat-window" id="chatWindow">
        <div class="chat-header">
            <span><i class="bi bi-robot"></i> Asistente de IA</span>
            <button class="btn-close btn-close-white" style="font-size: 12px;" onclick="toggleChat()"></button>
        </div>
        <div class="chat-messages" id="chatMessages">
            <div class="msg msg-ai">¡Hola! Soy el asistente virtual de La Pasadita. ¿En qué te puedo ayudar hoy?</div>
        </div>
        <div class="chat-input">
            <input type="text" id="chatInput" placeholder="Escribe tu mensaje..." onkeypress="handleEnter(event)">
            <button onclick="enviarMensajeIA()"><i class="bi bi-send-fill"></i></button>
        </div>
    </div>

    <!-- Footer Premium -->
    <footer class="footer-custom">
        <div class="container">
            <div class="row gap-4 gap-md-0">
                <div class="col-md-5">
                    <h5 class="info-nombre-tienda">Abarrotes La Pasadita</h5>
                    <p class="text-white-50">Tu tienda de confianza en Axtla de Terrazas. Ofrecemos abarrotes de calidad, frutas y verduras frescas y productos de limpieza directo a tu domicilio.</p>
                </div>
                <div class="col-md-4">
                    <h5>Horario de Atención</h5>
                    <p class="text-white-50"><i class="bi bi-clock"></i> <span class="info-horario-tienda">Cargando horario...</span></p>
                    <p class="text-white-50"><i class="bi bi-geo-alt"></i> Axtla de Terrazas, S.L.P.</p>
                </div>
                <div class="col-md-3">
                    <h5>Enlaces Útiles</h5>
                    <ul class="list-unstyled">
                        <li><a href="/#catalogo-seccion">Catálogo</a></li>
                        <li><a asp-controller="Admin" asp-action="Dashboard">Panel Administrativo</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom text-center">
                <p class="mb-0">&copy; @DateTime.Now.Year - Abarrotes La Pasadita. Proyecto Universitario Final.</p>
            </div>
        </div>
    </footer>

    <!-- Variables Globales para JavaScript de Autenticación -->
    <script>
        window.UsuarioId = @(User.Identity != null && User.Identity.IsAuthenticated ? User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value : "null");
        window.UsuarioRol = "@(User.Identity != null && User.Identity.IsAuthenticated ? User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value : "")";
    </script>

    <!-- Scripts Base -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function toggleChat() {
            var chat = document.getElementById("chatWindow");
            chat.style.display = (chat.style.display === "flex") ? "none" : "flex";
        }

        function handleEnter(e) {
            if (e.key === "Enter") enviarMensajeIA();
        }

        async function enviarMensajeIA() {
            var input = document.getElementById("chatInput");
            var msgs = document.getElementById("chatMessages");
            var txt = input.value.trim();
            if (!txt) return;

            // Agregar mensaje de usuario
            msgs.innerHTML += `<div class="msg msg-user">${txt}</div>`;
            input.value = "";
            msgs.scrollTop = msgs.scrollHeight;

            // Mostrar escribiendo...
            var typingId = "typing-" + Date.now();
            msgs.innerHTML += `<div class="msg msg-ai" id="${typingId}">...</div>`;
            msgs.scrollTop = msgs.scrollHeight;

            try {
                const response = await fetch('/api/ChatApi', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ Mensaje: txt })
                });

                document.getElementById(typingId).remove();

                if (response.ok) {
                    const data = await response.json();
                    msgs.innerHTML += `<div class="msg msg-ai">${data.respuesta}</div>`;
                } else {
                    msgs.innerHTML += `<div class="msg msg-ai" style="color:red">Error al contactar con la IA.</div>`;
                }
            } catch (error) {
                document.getElementById(typingId)?.remove();
                msgs.innerHTML += `<div class="msg msg-ai" style="color:red">Error de conexión.</div>`;
            }
            msgs.scrollTop = msgs.scrollHeight;
        }

        // Lógica del Clima (Open-Meteo API)
        document.addEventListener("DOMContentLoaded", () => {
            obtenerClima();
        });

        function obtenerClima() {
            // Intentar Geolocalización, sino usar CDMX por defecto (19.43, -99.13)
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(
                    pos => fetchWeather(pos.coords.latitude, pos.coords.longitude),
                    err => fetchWeather(19.4326, -99.1332) // Fallback CDMX
                );
            } else {
                fetchWeather(19.4326, -99.1332);
            }
        }

        async function fetchWeather(lat, lon) {
            try {
                const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current_weather=true`;
                const res = await fetch(url);
                if (!res.ok) throw new Error("Error API clima");
                
                const data = await res.json();
                const temp = data.current_weather.temperature;
                const wcode = data.current_weather.weathercode;
                
                let iconClass = "bi-cloud-sun";
                // Mapeo básico de WMO codes
                if (wcode === 0) iconClass = "bi-sun text-warning"; // Despejado
                else if (wcode >= 1 && wcode <= 3) iconClass = "bi-cloud-sun text-secondary"; // Nublado parcial
                else if (wcode >= 45 && wcode <= 48) iconClass = "bi-cloud-haze text-secondary"; // Niebla
                else if (wcode >= 51 && wcode <= 67) iconClass = "bi-cloud-rain text-info"; // Lluvia
                else if (wcode >= 71 && wcode <= 82) iconClass = "bi-cloud-snow text-primary"; // Nieve
                else if (wcode >= 95) iconClass = "bi-cloud-lightning-rain text-danger"; // Tormenta
                
                document.getElementById("weather-spinner").classList.add("d-none");
                
                const iconEl = document.getElementById("weather-icon");
                iconEl.className = `bi ${iconClass} me-2 fs-5`;
                iconEl.classList.remove("d-none");
                
                const tempEl = document.getElementById("weather-temp");
                tempEl.textContent = `${temp}°C`;
                tempEl.classList.remove("text-muted");
                tempEl.classList.add("text-dark");
                
            } catch (error) {
                console.error("Clima no disponible:", error);
                document.getElementById("weather-widget").classList.add("d-none");
            }
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
