@{
    ViewData["Title"] = "Catálogo - Abarrotes La Pasadita";
}

<!-- Banner de Bienvenida Estilo Héroe Premium -->
<div class="hero-section mt-3 fade-in-up">
    <div class="row align-items-center">
        <div class="col-md-8">
            <span class="hero-tag">Axtla de Terrazas, S.L.P.</span>
            <h1 class="display-4 fw-bold mb-3">Abarrotes "La Pasadita"</h1>
            <p class="lead mb-4">Productos frescos del campo a tu hogar. Realiza tus pedidos de forma silenciosa y recíbelos en la puerta de tu casa.</p>
            <div class="d-flex flex-wrap gap-3">
                <a href="#catalogo-seccion" class="btn btn-warning text-white fw-bold px-4 py-2" style="border-radius: var(--radius-sm);">
                    <i class="bi bi-shop"></i> Ver Catálogo
                </a>
                <div class="d-flex align-items-center gap-2 text-white-50">
                    <i class="bi bi-clock-history"></i>
                    <span class="small info-horario-tienda">Cargando horario...</span>
                </div>
            </div>
        </div>
        <div class="col-md-4 d-none d-md-block text-center position-relative">
            <div class="bg-white p-3 rounded-circle shadow-lg d-inline-block position-relative" style="width: 180px; height: 180px; border: 4px solid var(--accent);">
                <div class="d-flex flex-column align-items-center justify-content-center h-100 text-dark">
                    <span class="fw-bold text-uppercase" style="font-size: 0.75rem; letter-spacing: 1px; color: var(--primary-light);">Envío Local</span>
                    <span class="fs-2 fw-extrabold text-success" style="font-weight: 800;">$15</span>
                    <span class="small text-muted">Pesos mexicanos</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Sección del Catálogo Principal -->
<div id="catalogo-seccion" class="container py-4">
    <div class="row align-items-center mb-5 gap-3 gap-md-0">
        <!-- Buscador -->
        <div class="col-12 col-md-5">
            <div class="input-group shadow-sm" style="border-radius: var(--radius-sm); overflow: hidden;">
                <span class="input-group-text bg-white border-end-0 text-success"><i class="bi bi-search"></i></span>
                <input type="text" 
                       id="buscador-productos" 
                       class="form-control border-start-0 ps-0" 
                       placeholder="¿Qué estás buscando hoy?" 
                       oninput="buscarProductos(this.value)" 
                       style="box-shadow: none; border-color: #dee2e6;">
            </div>
        </div>
        
        <!-- Contenedor de Filtros de Categoría -->
        <div class="col-12 col-md-7">
            <div id="contenedor-filtros" class="d-flex flex-wrap gap-2 justify-content-md-end">
                <!-- Se cargará dinámicamente con AJAX -->
            </div>
        </div>
    </div>

    <!-- Rejilla de Productos -->
    <div class="row" id="contenedor-productos">
        <!-- Se cargará dinámicamente con AJAX -->
    </div>
</div>

@section Scripts {
    <script src="~/js/catalogo.js" asp-append-version="true"></script>
}
